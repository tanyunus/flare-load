msgid "FlarePress"
msgstr "FlarePress"

#. Description of the plugin
#: flare-press.php
msgid "WordPress plugin for uploading media directly to Cloudflare Images alongside the default uploader."
msgstr "Medyayı varsayılan yükleyicinin yanı sıra doğrudan Cloudflare Images'a yükleyen WordPress eklentisi."

